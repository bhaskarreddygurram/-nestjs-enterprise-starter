# ----------------------------------------------------------------------------
# Application
# ----------------------------------------------------------------------------
NODE_ENV=development
PORT=8000

# ----------------------------------------------------------------------------
# API
# ----------------------------------------------------------------------------
API_PREFIX=api
API_VERSION=v1

# ----------------------------------------------------------------------------
# Documentation
# ----------------------------------------------------------------------------
SWAGGER_ENABLED=true

# ----------------------------------------------------------------------------
# CORS  (comma-separated origins, or * for all)
# ----------------------------------------------------------------------------
CORS_ORIGINS=*

# ----------------------------------------------------------------------------
# Database (PostgreSQL)
# POSTGRES_* are consumed by docker-compose; DATABASE_URL is used by the app/Prisma
# ----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=enterprise_db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/enterprise_db?schema=public

# ----------------------------------------------------------------------------
# Redis
# ----------------------------------------------------------------------------
# REDIS_URL overrides the discrete fields below; use rediss:// for TLS.
# Managed providers (Render Key Value, Upstash, Redis Cloud) give you one.
# REDIS_URL=redis://:password@host:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
# Set to true for managed Redis that requires TLS (only when NOT using REDIS_URL)
REDIS_TLS=false

# ----------------------------------------------------------------------------
# JWT  (use a long random string in production, e.g. `openssl rand -base64 48`)
# ----------------------------------------------------------------------------
JWT_ACCESS_SECRET=dev_access_secret_change_me_in_production_please
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN_DAYS=7

# ----------------------------------------------------------------------------
# Rate limiting (requests per TTL window; auth routes are stricter)
# ----------------------------------------------------------------------------
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ----------------------------------------------------------------------------
# File uploads
# ----------------------------------------------------------------------------
UPLOAD_DIR=./uploads
UPLOAD_MAX_SIZE_MB=5
UPLOAD_ALLOWED_MIME=image/png,image/jpeg,image/gif,application/pdf,text/plain

# ----------------------------------------------------------------------------
# Mail
#   MAIL_TRANSPORT=console → logs emails to stdout (dev/CI)
#   MAIL_TRANSPORT=smtp    → real delivery (set MAIL_HOST + creds below)
#   secure=true for port 465 (implicit TLS); false for 587 (STARTTLS)
# ----------------------------------------------------------------------------
MAIL_TRANSPORT=console
MAIL_FROM=no-reply@enterprise.local
# MAIL_HOST=smtp.example.com
# MAIL_PORT=587
# MAIL_SECURE=false
# MAIL_USER=
# MAIL_PASSWORD=

# ----------------------------------------------------------------------------
# Security depth (Phase 10)
#   - lockout: account locks after N failed logins for M minutes
#   - password reset: token lifetime; APP_WEB_URL is the front-end base for the link
#   - 2FA: issuer shown in authenticator apps; challenge token lifetime (2-step login)
# ----------------------------------------------------------------------------
SECURITY_MAX_LOGIN_ATTEMPTS=5
SECURITY_LOCKOUT_MINUTES=15
PASSWORD_RESET_TTL_MINUTES=30
APP_WEB_URL=http://localhost:3000
TWO_FACTOR_ISSUER=Enterprise Starter
TWO_FACTOR_CHALLENGE_TTL=5m

# ----------------------------------------------------------------------------
# Observability (Phase 11)
#   - LOG_LEVEL: fatal|error|warn|info|debug|trace|silent (JSON logs in prod,
#     pretty-printed in development)
#   - METRICS_ENABLED: expose Prometheus metrics at GET /metrics
# ----------------------------------------------------------------------------
LOG_LEVEL=info
METRICS_ENABLED=true
