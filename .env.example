# ----------------------------------------------------------------------------
# Application
# ----------------------------------------------------------------------------
NODE_ENV=development
PORT=8000

# ----------------------------------------------------------------------------
# API
# ----------------------------------------------------------------------------
API_PREFIX=api
API_VERSION=v1

# ----------------------------------------------------------------------------
# Documentation
# ----------------------------------------------------------------------------
SWAGGER_ENABLED=true

# ----------------------------------------------------------------------------
# CORS  (comma-separated origins, or * for all)
# ----------------------------------------------------------------------------
CORS_ORIGINS=*

# ----------------------------------------------------------------------------
# Database (PostgreSQL)
# POSTGRES_* are consumed by docker-compose; DATABASE_URL is used by the app/Prisma
# ----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=enterprise_db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/enterprise_db?schema=public

# ----------------------------------------------------------------------------
# Redis
# ----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
